# 使用 RunPod 官方推荐的 PyTorch 基础镜像
FROM runpod/pytorch:2.1.0-py3.10-cuda11.8.0-devel-ubuntu22.04

WORKDIR /workspace

# 1. 系统依赖
RUN apt-get update && apt-get install -y libgl1-mesa-glx libglib2.0-0 && rm -rf /var/lib/apt/lists/*

# 2. 基础环境与 FastAPI (锁定关键版本以防冲突)
RUN pip install --no-cache-dir "numpy<2" "matplotlib<3.9" "opencv-python<4.10" "fastapi" "uvicorn" "httpx" "google-generativeai"

# 3. 安装 Node.js 和 Gemini CLI (可选，如果需要 agent 功能)
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    npm install -g @google/gemini-cli

# 4. OpenMMLab 核心组件
RUN pip install --no-cache-dir mmengine==0.10.7
RUN pip install --no-cache-dir mmcv==2.1.0 -f https://download.openmmlab.com/mmcv/dist/cu118/torch2.1/index.html
RUN pip install --no-cache-dir mmdet==3.3.0
RUN pip install --no-cache-dir mmpose==1.3.2

# 4. 项目配套工具
RUN pip install --no-cache-dir "runpod~=1.7.6" "trimesh>=4.0.0"

# 拷贝代码
COPY . /workspace/

# 设置环境变量
ENV PYTHONUNBUFFERED=1

# 启动 FastAPI 服务
CMD ["python", "fastapi_server.py"]
