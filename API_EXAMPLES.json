{
  "examples": [
    {
      "name": "推荐配置 (RTMPose-L + RTMW3D)",
      "description": "最佳平衡 - 精度94-96%，实时性好，推荐用于生产环境",
      "request": {
        "input": {
          "video_url": "https://example.com/golf_swing.mp4",
          "pose_model": "rtmpose-l",
          "pose3d_model": "rtmw3d-x",
          "club_type": "iron",
          "handedness": "right",
          "joint_smooth_win": 11,
          "club_smooth_win": 11,
          "view_transform": "rotate-180"
        }
      },
      "curl_command": "curl -X POST http://localhost:8000/runsync -H 'Content-Type: application/json' -d @example1.json"
    },
    {
      "name": "快速处理 (RTMPose-M + RTMW3D)",
      "description": "速度优先 - 速度最快，精度93%，适合实时预览",
      "request": {
        "input": {
          "video_url": "https://example.com/golf_swing.mp4",
          "pose_model": "rtmpose-m",
          "pose3d_model": "rtmw3d-x"
        }
      },
      "curl_command": "curl -X POST http://localhost:8000/runsync -H 'Content-Type: application/json' -d '{\"input\": {\"video_url\": \"...\", \"pose_model\": \"rtmpose-m\", \"pose3d_model\": \"rtmw3d-x\"}}'"
    },
    {
      "name": "最高精度 (ViTPose++ + RTMW3D)",
      "description": "精度优先 - 精度95%+，Vision Transformer架构，适合复杂背景",
      "request": {
        "input": {
          "video_url": "https://example.com/golf_swing.mp4",
          "pose_model": "vitpose++",
          "pose3d_model": "rtmw3d-x",
          "joint_smooth_win": 15,
          "club_smooth_win": 15
        }
      },
      "curl_command": "curl -X POST http://localhost:8000/runsync -H 'Content-Type: application/json' -d @example3.json"
    },
    {
      "name": "向后兼容 (Human + MotionBERT)",
      "description": "原始配置 - 保持原有行为，无需修改现有代码",
      "request": {
        "input": {
          "video_url": "https://example.com/golf_swing.mp4",
          "pose_model": "human",
          "pose3d_model": "motionbert_dstformer-ft-243frm_8xb32-120e_h36m"
        }
      },
      "curl_command": "curl -X POST http://localhost:8000/runsync -H 'Content-Type: application/json' -d @example4.json"
    },
    {
      "name": "本地文件处理",
      "description": "使用本地视频文件而不是URL",
      "request": {
        "input": {
          "video_path": "/workspace/inbox/my_golf_swing.mp4",
          "pose_model": "rtmpose-l",
          "pose3d_model": "rtmw3d-x",
          "club_type": "driver"
        }
      },
      "note": "需要通过 SCP/SSH 先将视频上传到服务器"
    },
    {
      "name": "高级参数调优",
      "description": "针对特定场景的参数调整",
      "request": {
        "input": {
          "video_url": "https://example.com/golf_swing.mp4",
          "pose_model": "rtmpose-l",
          "pose3d_model": "rtmw3d-x",
          "club_type": "wedge",
          "handedness": "left",
          "view_transform": "flip-x",
          "width": 1280,
          "height": 960,
          "joint_smooth_win": 13,
          "club_smooth_win": 13,
          "device": "cuda:0"
        }
      },
      "parameter_notes": {
        "joint_smooth_win": "增加此值以减少关键点抖动（范围: 5-25）",
        "club_smooth_win": "球杆平滑窗口（范围: 5-25）",
        "view_transform": "可选: none, rotate-180, flip-x, flip-y",
        "device": "GPU设备标识符"
      }
    }
  ],
  "model_selection_guide": {
    "decision_tree": {
      "question": "选择模型的考虑因素？",
      "options": [
        {
          "need": "需要实时处理",
          "recommendation": "RTMPose-M",
